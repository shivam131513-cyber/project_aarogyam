# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/gniot
POSTGRES_URI=postgresql://username:password@localhost:5432/gniot
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# Government API Integration
ABHA_API_URL=https://abha.abdm.gov.in/api
ABHA_CLIENT_ID=your-abha-client-id
ABHA_CLIENT_SECRET=your-abha-client-secret

NOTTO_API_URL=https://notto.nic.in/api
NOTTO_API_KEY=your-notto-api-key

AYUSHMAN_API_URL=https://pmjay.gov.in/api
AYUSHMAN_API_KEY=your-ayushman-api-key

# External Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# AI/ML Service
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=your-ml-service-api-key

# Maps and Location
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
